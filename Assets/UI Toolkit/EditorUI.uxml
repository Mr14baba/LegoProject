                    <ui:ToggleButtonGroup label="" value="0000001" is-multiple-selection="false" allow-empty-selection="false" name="ButtonGroupLegoSelected" focusable="true" style="align-items: stretch; align-self: center;">
                        <LegoBlockButton lego-available="project://database/Assets/UI%20Toolkit/LegoAvailable.asset?fileID=11400000&amp;guid=aee108ad2c5881b4eb8209630b83ab9f&amp;type=2#LegoAvailable" enabled="true" style="margin-top: 0; margin-bottom: 0;"/>
