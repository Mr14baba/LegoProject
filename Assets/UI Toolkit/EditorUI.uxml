                        <LegoBlockButton lego-available="project://database/Assets/UI%20Toolkit/LegoAvailable.asset?fileID=11400000&amp;guid=aee108ad2c5881b4eb8209630b83ab9f&amp;type=2#LegoAvailable" lego-index="3" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0;"/>
                        <LegoBlockButton lego-available="project://database/Assets/UI%20Toolkit/LegoAvailable.asset?fileID=11400000&amp;guid=aee108ad2c5881b4eb8209630b83ab9f&amp;type=2#LegoAvailable" lego-index="4" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0;"/>
                        <LegoBlockButton lego-available="project://database/Assets/UI%20Toolkit/LegoAvailable.asset?fileID=11400000&amp;guid=aee108ad2c5881b4eb8209630b83ab9f&amp;type=2#LegoAvailable" lego-index="5" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0;"/>
