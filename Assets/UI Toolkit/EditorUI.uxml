        <ui:VisualElement name="WarningScreen" style="flex-grow: 0; background-color: rgb(47, 47, 47); position: relative; width: 500px; align-self: center; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); display: none; visibility: visible;">
            <ui:Label text="WARNING !" style="color: rgb(255, 255, 255); font-size: 40px; margin-left: 10px; margin-right: 10px; margin-top: 10px;"/>
            <ui:Label text="All unsaved progress will be lost !" name="WarningLabel" style="background-color: rgb(77, 77, 77); font-size: 20px; color: rgb(255, 255, 255); white-space: normal; -unity-text-align: middle-left; padding-left: 5px; padding-right: 5px; padding-top: 20px; padding-bottom: 20px; margin-left: 10px; margin-right: 10px; -unity-font-style: bold; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; border-bottom-color: rgb(255, 47, 47); border-left-color: rgb(255, 47, 47); border-right-color: rgb(255, 47, 47); border-top-color: rgb(255, 47, 47); border-bottom-width: 2px; border-left-width: 2px; border-top-width: 2px; border-right-width: 2px;"/>
